{
  "$schema": "https://opencode.ai/config.json",
  "model": "alibaba-coding-plan-cn/glm-5",
  "plugin": ["oh-my-openagent@latest"],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    }
  },
  "provider": {
    "APIRouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "APIRouter",
      "options": {
        "baseURL": "https://airouter.cloud/v1"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "claude-sonnet-4-6"
        }
      }
    },
    "AstronCodingPlan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "讯飞星辰 Coding Plan",
      "options": {
        "baseURL": "https://maas-coding-api.cn-huabei-1.xf-yun.com/v2",
        "apiKey": "a5e17b4823c1b956d44aee522bf1c5d8:NmUwNTgwNTI1ODY0NWE3YTgxODg4NTZi"
      },
      "models": {
        "astron-code-latest": {
          "name": "Astron Coding Plan"
        }
      }
    },
    "JDCodingPlan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "JD Coding Plan",
      "options": {
        "baseURL": "https://modelservice.jdcloud.com/coding/openai/v1",
        "apiKey": "pk-8cdfaa53-5e73-47fa-9967-89f472d1aa0a"
      },
      "models": {
        "DeepSeek-V3.2": {
          "name": "DeepSeek-V3.2",
          "limit": {
            "context": 128000,
            "output": 64000
          }
        },
        "GLM-5": {
          "name": "GLM-5",
          "limit": {
            "context": 200000,
            "output": 32000
          }
        },
        "GLM-4.7": {
          "name": "GLM-4.7",
          "limit": {
            "context": 200000,
            "output": 128000
          }
        },
        "MiniMax-M2.5": {
          "name": "MiniMax-M2.5",
          "limit": {
            "context": 200000,
            "output": 128000
          }
        },
        "Kimi-K2.5": {
          "name": "Kimi-K2.5",
          "limit": {
            "context": 256000,
            "output": 128000
          }
        },
        "Kimi-K2-Turbo": {
          "name": "Kimi-K2-Turbo",
          "limit": {
            "context": 256000,
            "output": 32000
          }
        },
        "Qwen3-Coder": {
          "name": "Qwen3-Coder",
          "limit": {
            "context": 64000,
            "output": 8000
          }
        }
      }
    }
  }
}
